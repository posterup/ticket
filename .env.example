# Copy to .env.local for local dev, and set these in Vercel → Project → Settings
# → Environment Variables for production. Never commit real secrets.

# sms.ir SMS gateway (https://sms.ir)
SMSIR_API_KEY=
SMSIR_LINE_NUMBER=

# Resend email (https://resend.com) — no mail server needed
RESEND_API_KEY=
EMAIL_FROM="پوستر <noreply@yourdomain.ir>"
